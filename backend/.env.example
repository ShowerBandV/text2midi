# text2midi 环境变量配置
# 复制此文件为 .env 后填入真实值

# [必需] LLM API Key（用于 AI 生成）
# 支持 DeepSeek / OpenAI 等兼容 API
OPENAI_API_KEY=sk-your-key-here

# [可选] 模型名称（默认 deepseek-chat）
# OPENAI_MODEL=deepseek-chat

# [可选] API 地址（默认 https://api.deepseek.com/v1）
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# [可选] 服务端口（默认 8080）
# PORT=8080
